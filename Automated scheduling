# 🧵 後台計算執行緒
# ==========================================
class CalculationThread(QThread):
    log_signal = Signal(str)
    result_signal = Signal(list)
    finished_signal = Signal()

    def __init__(self, input_data, driver):
        super().__init__()
        self.data = input_data
        self.driver = driver

    def run(self):
        self.log_signal.emit(f"📂 正在載入 Excel 資料庫: {CFG['excel_path']}...")
        if not gmaps: self.log_signal.emit(f"⚠️ 警告: 未偵測到有效的 API Key，路程計算將使用預設值。")
        
        try:
            df = pd.read_excel(CFG['excel_path'], usecols="G,AW", engine='openpyxl')
            address_db = {str(name).strip(): str(addr).strip() for name, addr in zip(df.iloc[:, 0], df.iloc[:, 1])}
            self.log_signal.emit(f"✅ 地址庫載入完成，共 {len(address_db)} 筆。")
        except Exception as e:
            self.log_signal.emit(f"❌ Excel 讀取失敗: {e}")
            return

        final_results_storage = []
        try:
            target_days = self.data['days']
            target_gender = self.data['gender']
            required_segments = self.data['segments']
            case_address = self.data['address']

            for day_idx in target_days:
                week_map = {1:"週一", 2:"週二", 3:"週三", 4:"週四", 5:"週五", 6:"週六", 7:"週日"}
                day_name = week_map.get(day_idx, f"週{day_idx}")
                self.log_signal.emit(f"\n🔎 掃描中: [{day_name}]")

                day_to_col_map = {1: 3, 2: 4, 3: 5, 4: 6, 5: 7, 6: 8, 7: 2}
                column_index = day_to_col_map.get(day_idx, 3) 
                
                rows = self.driver.find_elements(By.XPATH, '//*[@id="page-wrapper"]//table/tbody/tr')
                XPATH_TARGET_COL_CARDS = f"./td[{column_index}]//div[contains(@class, 'CalendarCard')]"

                caregiver_schedules = {}

                for row in rows:
                    try:
                        try: raw_caregiver_name = row.find_element(By.XPATH, "./td[1]//a").text.strip()
                        except: continue
                        if not raw_caregiver_name: continue
                        
                        cg_name = None
                        for db_name in CAREGIVER_GENDERS.keys():
                            if db_name in raw_caregiver_name: cg_name = db_name; break
                        if not cg_name: continue 

                        cards = row.find_elements(By.XPATH, XPATH_TARGET_COL_CARDS)
                        personal_schedule = [] 
                        is_off = False 

                        for card in cards:
                            if not card.is_displayed(): continue
                            text = card.text.strip()
                            if "請假 (無代)" in text: continue
                            if "特休" in text or "病假" in text or "事假" in text: is_off = True; break
                            if not re.search(r"\d{1,2}:\d{2}", text): continue
                            
                            found_time_str = ""
                            for line in text.split('\n'):
                                if ":" in line and "-" in line: found_time_str = line; break
                            
                            found_cn = "未知"; found_addr = None
                            for db_n in address_db:
                                if db_n in text: found_cn = db_n; found_addr = address_db[db_n]; break
                            
                            if found_time_str:
                                personal_schedule.append({ "case_name": found_cn, "address": found_addr, "time": found_time_str })
                        
                        if not is_off: caregiver_schedules[cg_name] = personal_schedule
                    except: continue

                self.log_signal.emit(f"   -> 取得 {len(caregiver_schedules)} 位居服員班表")

                # --- 演算法開始 ---
                for segment in required_segments:
                    seg_name = segment['name']
                    req_time_str = segment['time']
                    duration = segment['duration']
                    req_start_time = datetime.strptime(f"{datetime.now().date()} {req_time_str}", "%Y-%m-%d %H:%M") if req_time_str else None

                    for caregiver, schedule in caregiver_schedules.items():
                        if target_gender:
                            if get_caregiver_gender(caregiver) != target_gender: continue 

                        schedule.sort(key=lambda x: parse_time_range(x['time'])[0] or datetime.max)
                        
                        # 空班表處理
                        if not schedule:
                            final_results_storage.append({
                                "day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "完美 (全天空檔)",
                                "detail": "全日無行程。", "sort_score": 1
                            })
                            continue

                        # 建立檢查鏈
                        check_list = [{"time": f"{DAY_START_HOUR}-{DAY_START_HOUR}", "address": None, "case_name": "上班"}]
                        check_list.extend(schedule)
                        check_list.append({"time": f"{DAY_END_HOUR}-{DAY_END_HOUR}", "address": None, "case_name": "下班"})

                        # 轉派邏輯
                        if req_start_time:
                            for job in schedule:
                                j_start, j_end = parse_time_range(job['time'])
                                req_end = req_start_time + timedelta(minutes=duration)
                                if max(j_start, req_start_time) < min(j_end, req_end):
                                    replacements = check_reassignment_possibility(job, caregiver, caregiver_schedules, day_name)
                                    if replacements:
                                        msg = f"建議將【{job['case_name']}】轉給 {replacements[0]}，空出時段。"
                                        final_results_storage.append({"day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "🔴 轉派策略", "detail": msg, "sort_score": 3})

                        # 空檔檢查邏輯
                        for i in range(len(check_list) - 1):
                            prev = check_list[i]; next_j = check_list[i+1]
                            p_start, p_end = parse_time_range(prev['time'])
                            n_start, _ = parse_time_range(next_j['time'])
                            
                            if req_start_time and n_start < req_start_time: continue

                            t1 = get_travel_time(prev['address'], case_address) if prev['address'] else 0
                            t2 = get_travel_time(case_address, next_j['address']) if next_j['address'] else 0
                            earliest_arrival = p_end + timedelta(minutes=t1)
                            
                            # 指定時間模式
                            if req_start_time:
                                if earliest_arrival <= req_start_time:
                                    # 檢查是否撞後面
                                    req_end = req_start_time + timedelta(minutes=duration)
                                    arrive_next = req_end + timedelta(minutes=t2 + MIN_TRAVEL_BUFFER)
                                    
                                    if arrive_next <= n_start:
                                        msg = f"可於 {prev['case_name']} 後準時抵達。"
                                        final_results_storage.append({"day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "✅ 完美時段", "detail": msg, "sort_score": 1})
                                    else:
                                        # 撞後面 -> 骨牌順延
                                        overlap = int((arrive_next - n_start).total_seconds() / 60)
                                        if overlap <= MAX_SHIFT_LIMIT:
                                            ok, impact_str, _ = simulate_push_right(check_list, i+1, overlap)
                                            if ok:
                                                final_results_storage.append({"day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "🟠 連鎖挪移", "detail": f"需將後續行程順延：{impact_str}", "sort_score": 2})

                                else:
                                    # 遲到 -> 挪前案
                                    diff = int((earliest_arrival - req_start_time).total_seconds() / 60)
                                    # 簡單檢查前案空檔 (簡化版)
                                    if i > 0:
                                        _, pp_end = parse_time_range(check_list[i-1]['time'])
                                        p_start_real, _ = parse_time_range(prev['time'])
                                        if (p_start_real - pp_end).total_seconds()/60 > (diff + 15):
                                            final_results_storage.append({"day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "🟡 挪移前案", "detail": f"請前案 {prev['case_name']} 提早 {diff} 分結束即可。", "sort_score": 2})

                            # 彈性模式
                            elif not req_start_time:
                                total_need = t1 + duration + t2 + MIN_TRAVEL_BUFFER
                                gap = (n_start - p_end).total_seconds() / 60
                                if gap >= total_need:
                                    suggest_start = earliest_arrival + timedelta(minutes=5)
                                    suggest_end = suggest_start + timedelta(minutes=duration)
                                    final_results_storage.append({"day": day_name, "segment": seg_name, "caregiver": caregiver, "type": "✅ 彈性安插", "detail": f"建議 {suggest_start.strftime('%H:%M')}~{suggest_end.strftime('%H:%M')}", "sort_score": 1})

        except Exception as e:
            self.log_signal.emit(f"❌ 運算發生錯誤: {str(e)}")
        
        finally:
            self.driver.quit()
            self.result_signal.emit(final_results_storage)
            self.finished_signal.emit()


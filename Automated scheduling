# 🧠 核心邏輯工具函式
# ==========================================
def get_travel_time(origin, destination):
    if not gmaps: return 30 # 無 API Key 時的 Fallback
    if not origin or not destination: return 0
    if origin == destination: return 0
    try:
        matrix = gmaps.distance_matrix(origin, destination, mode='driving', language='zh-TW')
        if matrix['rows'][0]['elements'][0]['status'] != 'OK': return 999
        seconds = matrix['rows'][0]['elements'][0]['duration']['value']
        return int(seconds / 60)
    except: return 30 

def parse_time_range(time_str):
    try:
        today = datetime.now().date()
        clean_time = time_str.split(' ')[0]
        start_str, end_str = clean_time.split('-')
        return datetime.strptime(f"{today} {start_str}", "%Y-%m-%d %H:%M"), datetime.strptime(f"{today} {end_str}", "%Y-%m-%d %H:%M")
    except: return None, None

def get_day_boundaries():
    today = datetime.now().date()
    return datetime.strptime(f"{today} {DAY_START_HOUR}", "%Y-%m-%d %H:%M"), datetime.strptime(f"{today} {DAY_END_HOUR}", "%Y-%m-%d %H:%M")

def get_caregiver_gender(raw_name):
    for name_key, gender in CAREGIVER_GENDERS.items():
        if name_key in raw_name: return gender
    return "未知"

def calculate_chain_slack(check_list, current_idx, direction):
    total_slack = 0
    if direction == 'left':
        for k in range(current_idx - 1, -1, -1):
            this_job = check_list[k]; next_job = check_list[k+1]
            _, this_end = parse_time_range(this_job['time'])
            next_start, _ = parse_time_range(next_job['time'])
            gap = (next_start - this_end).total_seconds() / 60
            if this_job['case_name'] == "上班": total_slack += gap; break
            else: total_slack += max(0, gap - MIN_TRAVEL_BUFFER)
    elif direction == 'right':
        for k in range(current_idx + 1, len(check_list) - 1):
            this_job = check_list[k]; next_job = check_list[k+1]
            _, this_end = parse_time_range(this_job['time'])
            next_start, _ = parse_time_range(next_job['time'])
            gap = (next_start - this_end).total_seconds() / 60
            if next_job['case_name'] == "下班": total_slack += gap; break
            else: total_slack += max(0, gap - MIN_TRAVEL_BUFFER)
    return total_slack

def check_reassignment_possibility(conflicting_job, original_caregiver, day_schedules, day_name):
    suggestions = []
    job_start, job_end = parse_time_range(conflicting_job['time'])
    job_duration = (job_end - job_start).total_seconds() / 60
    job_addr = conflicting_job['address']
    for candidate, schedule in day_schedules.items():
        if candidate == original_caregiver: continue
        check_list = []
        check_list.append({"time": f"{DAY_START_HOUR}-{DAY_START_HOUR}", "address": None, "case_name": "上班"})
        check_list.extend(schedule)
        check_list.append({"time": f"{DAY_END_HOUR}-{DAY_END_HOUR}", "address": None, "case_name": "下班"})
        for i in range(len(check_list) - 1):
            prev = check_list[i]; next_j = check_list[i+1]
            _, prev_end = parse_time_range(prev['time'])
            next_start, _ = parse_time_range(next_j['time'])
            gap = (next_start - prev_end).total_seconds() / 60
            t1 = get_travel_time(prev['address'], job_addr) if prev['address'] else 0
            t2 = get_travel_time(job_addr, next_j['address']) if next_j['address'] else 0
            total_needed = t1 + job_duration + t2 + 15
            if gap >= total_needed:
                arrival = prev_end + timedelta(minutes=t1)
                if arrival <= job_start:
                    finish = job_start + timedelta(minutes=job_duration)
                    arrive_next = finish + timedelta(minutes=t2 + 15)
                    if arrive_next <= next_start:
                        suggestions.append(candidate); break
    return suggestions

def simulate_push_right(check_list, start_idx, push_minutes):
    impacted_details = []
    current_delay = push_minutes
    for k in range(start_idx, len(check_list) - 1): 
        this_job = check_list[k]
        next_job = check_list[k+1]
        if this_job['case_name'] == "下班": break
        orig_start, orig_end = parse_time_range(this_job['time'])
        new_start = orig_start + timedelta(minutes=current_delay)
        new_end = orig_end + timedelta(minutes=current_delay)
        impacted_details.append(f"【{this_job['case_name']}】順延至 {new_start.strftime('%H:%M')}")
        
        if next_job['case_name'] == "下班":
            day_end_limit = get_day_boundaries()[1]
            if new_end > day_end_limit: return False, "超過下班時間", 0
            else: return True, "、".join(impacted_details), current_delay
        else:
            next_orig_start, _ = parse_time_range(next_job['time'])
            t_travel = get_travel_time(this_job['address'], next_job['address'])
            arrive_next = new_end + timedelta(minutes=t_travel + MIN_TRAVEL_BUFFER)
            if arrive_next > next_orig_start:
                added_delay = (arrive_next - next_orig_start).total_seconds() / 60
                current_delay = added_delay 
                if current_delay > MAX_SHIFT_LIMIT: return False, f"延遲擴大至 {int(current_delay)} 分鐘", 0
            else: return True, "、".join(impacted_details), push_minutes
    return True, "、".join(impacted_details), push_minutes


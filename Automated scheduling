        self.export_btn = QPushButton("💾 匯出 Excel")
        self.export_btn.setMinimumHeight(50)
        self.export_btn.clicked.connect(self.export_excel)
        self.export_btn.setEnabled(False)
        
        btn_layout.addWidget(self.run_btn)
        btn_layout.addWidget(self.export_btn)
        left_layout.addLayout(btn_layout)

        # 右側結果與日誌 (Splitter Right)
        right_splitter = QSplitter(Qt.Vertical)
        
        # 結果表格
        self.result_table = QTableWidget()
        self.result_table.setColumnCount(5)
        self.result_table.setHorizontalHeaderLabels(["日期", "時段", "居服員", "類型", "建議內容"])
        self.result_table.horizontalHeader().setSectionResizeMode(4, QHeaderView.Stretch)
        right_splitter.addWidget(self.result_table)
        
        # 系統日誌
        log_group = QGroupBox("📟 系統終端機 (System Log)")
        log_layout = QVBoxLayout()
        self.log_area = QTextEdit()
        self.log_area.setReadOnly(True)
        log_layout.addWidget(self.log_area)
        log_group.setLayout(log_layout)
        right_splitter.addWidget(log_group)

        # 組合左右
        main_splitter = QSplitter(Qt.Horizontal)
        main_splitter.addWidget(left_panel)
        main_splitter.addWidget(right_splitter)
        main_splitter.setStretchFactor(1, 2)
        main_layout.addWidget(main_splitter)

    def log(self, message):
        t = datetime.now().strftime("%H:%M:%S")
        self.log_area.append(f"[{t}] {message}")
        self.log_area.verticalScrollBar().setValue(self.log_area.verticalScrollBar().maximum())

    def start_calculation(self):
        # 收集資料
        target_days = [d for d, cb in self.day_checks if cb.isChecked()]
        if not target_days: QMessageBox.warning(self, "錯誤", "請至少選擇一天！"); return
        
        segs = []
        has_seg = False
        for ui in self.segments_ui:
            if ui["cb"].isChecked():
                has_seg = True
                segs.append({"name": ui["name"], "time": ui["time"].currentText(), "duration": ui["dur"].currentData()})
        if not has_seg:
            segs.append({"name": "彈性時段", "time": None, "duration": self.general_duration.currentData()})

        input_data = {
            "name": self.name_input.text(),
            "address": self.addr_input.text(),
            "gender": "女" if "女" in self.gender_combo.currentText() else "男" if "男" in self.gender_combo.currentText() else None,
            "days": target_days,
            "segments": segs
        }

        # 啟動流程
        self.run_btn.setEnabled(False)
        self.export_btn.setEnabled(False)
        self.result_table.setRowCount(0)
        self.log("⏳ 正在啟動 Chrome 瀏覽器...")
        
        try:
            options = webdriver.ChromeOptions()
            # options.add_argument("--headless") # 若要背景執行可解開
            self.driver = webdriver.Chrome(options=options)
            self.driver.get(CFG['login_url'])
            
            msg = QMessageBox()
            msg.setWindowTitle("登入等待")
            msg.setText("請在瀏覽器完成登入並切換至【排班表】頁面。\n\n完成後點擊 OK。")
            msg.setStyleSheet("background-color: #333; color: white;")
            msg.exec()
            
            self.thread = CalculationThread(input_data, self.driver)
            self.thread.log_signal.connect(self.log)
            self.thread.result_signal.connect(self.show_results)
            self.thread.finished_signal.connect(self.task_finished)
            self.thread.start()
            
        except Exception as e:
            self.log(f"❌ 啟動失敗: {e}")
            self.run_btn.setEnabled(True)

    def show_results(self, results):
        self.results_data = results
        if not results:
            self.log("😭 未找到符合的時段。")
            QMessageBox.information(self, "結果", "找不到符合條件的時段。")
            return
            
        results.sort(key=lambda x: x['sort_score'])
        self.result_table.setRowCount(len(results))
        for i, item in enumerate(results):
            self.result_table.setItem(i, 0, QTableWidgetItem(item['day']))
            self.result_table.setItem(i, 1, QTableWidgetItem(item['segment']))
            self.result_table.setItem(i, 2, QTableWidgetItem(item['caregiver']))
            
            type_item = QTableWidgetItem(item['type'])
            if "完美" in item['type']: type_item.setForeground(QColor("#4caf50"))
            elif "轉派" in item['type']: type_item.setForeground(QColor("#f44336"))
            else: type_item.setForeground(QColor("#ff9800"))
            type_item.setFont(QFont("Microsoft JhengHei", 9, QFont.Bold))
            
            self.result_table.setItem(i, 3, type_item)
            self.result_table.setItem(i, 4, QTableWidgetItem(item['detail']))
            
        self.export_btn.setEnabled(True)
        self.log(f"✅ 計算完成，共找到 {len(results)} 個方案。")

    def export_excel(self):
        if not self.results_data: return
        path, _ = QFileDialog.getSaveFileName(self, "儲存檔案", "排班建議.xlsx", "Excel Files (*.xlsx)")
        if path:
            try:
                df = pd.DataFrame(self.results_data)
                # 清理不需要的欄位
                if 'sort_score' in df.columns: del df['sort_score']
                df.columns = ["日期", "時段", "居服員", "類型", "詳細建議"]
                df.to_excel(path, index=False)
                self.log(f"💾 檔案已儲存至: {path}")
                os.startfile(path)
            except Exception as e:
                QMessageBox.critical(self, "錯誤", f"儲存失敗: {e}")

    def task_finished(self):
        self.run_btn.setEnabled(True)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyleSheet(DARK_STYLESHEET)
    window = MainWindow()
    window.show()
    sys.exit(app.exec())
